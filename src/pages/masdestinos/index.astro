                    if (error) throw error;
                    alert("¡Reporte enviado! Gracias por ayudar a la comunidad.");
                    const cardHook = document.getElementById(`vuelo-hook-${idVuelo}`);
                    if(cardHook) cardHook.style.opacity = '0.3';
                } catch (err) {
