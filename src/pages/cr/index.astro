                if (diferenciaSegundos < 60) return `Hace ${diferenciaSegundos} seg`;
                const diferenciaMinutos = Math.floor(diferenciaSegundos / 60);
                if (diferenciaMinutos < 60) return `Hace ${diferenciaMinutos} min`;
