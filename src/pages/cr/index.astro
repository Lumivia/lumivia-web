                        containerHook.className = "max-w-2xl mx-auto mb-20"; 
                        
                        document.getElementById('hero-section').style.display = 'none';
                        document.getElementById('newsletter-section').style.display = 'none';
                        document.getElementById('titulo-radar').style.display = 'none';
                        document.getElementById('contenedor-radar').style.display = 'none';
                        document.getElementById('btn-radar-completo').style.display = 'none';
                        
                        renderHookDeals(data);
                    } else {
                        const curacion = curarOfertas(data, paisActual);
                        renderHookDeals(curacion.hookDeals);
                        renderRadarDeals(curacion.radarDeals);
                    }

                } catch (err) {
                    console.error("Error al cargar Supabase:", err);
                    const container = document.getElementById('hook-deals');
                    if(container) {
                        container.innerHTML = `
                            <div class="col-span-full text-center text-red-400 py-10 font-medium" id="loader">
                                Error de conexión. Revisa la consola.
                            </div>
                        `;
                    }
                }
            }

            // *** ESTA ES LA FUNCIÓN LIMPIA, SIN EL CÓDIGO DE SCHEMA DUPLICADO ***
            function renderHookDeals(deals) {
                const container = document.getElementById('hook-deals');
                if(!container) return;
                
                container.innerHTML = ''; 

                deals.forEach(deal => {
                    const img = deal.url_imagen || "https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=800&q=80";
                    const titulo = deal.titulo_gancho || "Oferta Especial";
                    const precio = deal.precio || "Consultar";
                    const tiempoTranscurrido = calcularTiempoTranscurrido(deal.created_at);
                    const fechasCortas = `${formatearFechaCorta(deal.fecha_salida)} - ${formatearFechaCorta(deal.fecha_regreso)}`;
                    
                    const nacionales = destinosNacionales[paisActual] || [];
                    const esInternacional = !nacionales.includes(deal.destino);
                    
                    const esVip = deal.tipo_vuelo === 'directo';
                    const badgeVip = esVip 
                        ? `
                            <div class="absolute top-4 right-4 badge-vip-glass text-white text-[10px] font-black px-3 py-1.5 rounded-full z-10 flex items-center gap-1.5 uppercase tracking-widest shadow-lg">
                               <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
                               Directo
                           </div>
                          ` 
                        : '';

                    const etiquetaHot = (deal.calidad_oferta >= 9)
                        ? `
                            <span class="text-red-500 font-extrabold flex items-center gap-1 text-[10px] uppercase tracking-wider">
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"></path></svg> 
                                HOT
                            </span>
                          `
                        : '';

                    const monedaDeal = (deal.moneda || deal.currency || monedaActual).toUpperCase();

                    const amenidadesLinea = `
                        <div class="flex items-center flex-wrap gap-2 text-[10px] font-semibold text-gray-500 mb-6 uppercase tracking-widest">
                            <span class="flex items-center gap-1">
                                <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg> 
                                Hospedaje
                            </span>
                            <span class="text-gray-300">•</span>
                            <span class="flex items-center gap-1">
                                <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.5 21a2.5 2.5 0 005-5V5a2 2 0 00-2-2h-3.5M10 21H5a2 2 0 01-2-2V5a2 2 0 012-2h5m4 18h-4"></path></svg> 
                                Tours
                            </span>
                            ${esInternacional ? `
                                <span class="text-gray-300">•</span>
                                <span class="flex items-center gap-1">
                                    <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 117.778 0M12 20h.01m-7.08-7.071a10 10 0 1114.142 0"></path></svg> 
                                    eSIM
                                </span>
                            ` : ''}
                        </div>
                    `;

                    const card = document.createElement('article');
                    card.id = `vuelo-hook-${deal.id}`;
                    card.className = "card-minimal flex-none w-[85vw] md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] snap-center flex flex-col group cursor-pointer hover:shadow-xl transition-shadow duration-300";
                    card.onclick = () => abrirModalPaquete(deal.id); 
                    
                    card.innerHTML = `
                        <div class="relative h-56 overflow-hidden bg-gray-100">
                            <img src="${img}" alt="${titulo}" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out">
                            <div class="absolute inset-0 bg-gradient-to-t from-lumiDark/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-md text-lumiDark text-[10px] font-bold px-3 py-1.5 rounded-full shadow-sm tracking-wide border border-white/50 uppercase flex items-center gap-1">
                                ⏱️ ${tiempoTranscurrido}
                            </div>
                            ${badgeVip}
                            <button onclick="reportarCambioPrecio('${deal.id}')" title="¿El precio subió? Repórtalo" class="absolute bottom-3 right-3 bg-white/80 hover:bg-red-50 text-gray-500 hover:text-red-500 backdrop-blur-sm p-2.5 rounded-full shadow-sm border border-white/50 transition-colors z-10">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-1 6-1-1H11.5l-1-1H5v10m0 0h4"></path></svg>
                            </button>
                        </div>
                        
                        <div class="p-6 flex flex-col flex-grow bg-white relative">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center gap-2">
                                    <div class="text-[11px] font-extrabold text-gray-400 uppercase tracking-widest">
                                        <span>${deal.origen || 'ORG'}</span>
                                        <span class="mx-0.5 font-normal text-gray-300">➔</span>
                                        <span>${deal.destino || 'DST'}</span>
                                    </div>
                                    ${etiquetaHot}
                                </div>
                                
                                <div class="text-[10px] font-bold text-gray-400 uppercase tracking-wider flex items-center gap-1">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    ${fechasCortas}
                                </div>
                            </div>
                            
                            <h3 class="text-xl font-bold mb-4 text-lumiDark group-hover:text-lumiCyan transition-colors leading-snug line-clamp-2">${titulo}</h3>
                            
                            ${amenidadesLinea}

                            <div class="mt-auto pt-5 border-t border-gray-100 flex items-center justify-between">
                                <div>
                                    <p class="text-[9px] text-gray-400 uppercase tracking-widest font-bold mb-0.5">Vuelo Id/Vt</p>
                                    <p class="text-2xl font-black text-lumiDark leading-none tracking-tight">$${Number(precio).toLocaleString('en-US')} <span class="text-xs font-semibold text-gray-400">${monedaDeal}</span></p>
                                </div>
                                
                                <div class="flex items-center gap-3">
                                    <button onclick="copiarUrlUnica('${deal.id}')" title="Copiar enlace" class="bg-gray-50 hover:bg-gray-200 text-gray-500 p-2 rounded-lg transition-colors shadow-sm">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                                    </button>
                                    <span class="text-lumiCyan hover:text-lumiCyanDark font-semibold text-sm flex items-center gap-1 transition-colors">
                                        Explorar <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                    </span>
                                </div>
                            </div>
                        </div>
                    `;
                    container.appendChild(card);
                });

                if (!window.carruselIniciado && deals.length > 0) {
                    window.carruselIniciado = true;
                    const scrollContainer = document.getElementById('hook-deals');
                    
                    setInterval(() => {
                        if (!scrollContainer || scrollContainer.children.length === 0) return;
                        const maxScroll = scrollContainer.scrollWidth - scrollContainer.clientWidth;
                        
                        if (scrollContainer.scrollLeft >= maxScroll - 10) {
                            scrollContainer.scrollTo({ left: 0, behavior: 'smooth' });
                        } else {
                            const avance = scrollContainer.children[0].offsetWidth + 24; 
                            scrollContainer.scrollBy({ left: avance, behavior: 'smooth' });
                        }
                    }, 5000); 
                }
            }

            function renderRadarDeals(deals) {
                const container = document.getElementById('radar-deals');
                if(!container) return;
                
                if(deals.length === 0) {
                    container.innerHTML = '<li class="p-6 text-gray-400 text-center">No hay más destinos por ahora.</li>';
                    return;
                }
                
                container.innerHTML = '';

                deals.forEach(deal => {
                    const titulo = deal.titulo_gancho || "Destino Sorpresa";
                    const img = deal.url_imagen || "https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=150&q=80";
                    const precio = deal.precio || "0";
                    const destino = deal.destino || "Mundo";
                    const origenHtml = deal.origen 
                        ? `<span class="font-bold text-gray-400">${deal.origen}</span> <span class="mx-1 text-gray-300">➔</span>` 
                        : '';
                    
                    const monedaDeal = (deal.moneda || deal.currency || monedaActual).toUpperCase();
                    const hotBadge = (deal.calidad_oferta >= 9) 
                        ? `<span class="text-red-500 font-bold ml-1" title="Alta Demanda">🔥</span>` 
                        : '';

                    const li = document.createElement('li');
                    li.className = "p-3 sm:px-6 sm:py-4 hover:bg-gray-50/80 transition-colors flex flex-col sm:flex-row sm:items-center justify-between gap-4 cursor-pointer";
                    li.onclick = () => abrirModalPaquete(deal.id); 
                    
                    li.innerHTML = `
                        <div class="flex items-center gap-4">
                            <img src="${img}" class="h-12 w-12 rounded-lg object-cover shadow-sm border border-gray-200 hidden sm:block">
                            <div>
                                <h4 class="font-bold text-lumiDark text-base flex items-center flex-wrap gap-1">
                                    ${titulo} ${hotBadge}
                                </h4>
                               <div class="flex flex-wrap items-center text-xs text-gray-500 mt-1 font-medium gap-2">
                                    <div class="flex items-center">
                                        ${origenHtml}
                                        <span class="font-bold text-gray-400">${destino}</span>
                                    </div>
                                    <div class="flex items-center text-gray-400 text-[11px] font-bold">
                                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        ${formatearFechaCorta(deal.fecha_salida)} - ${formatearFechaCorta(deal.fecha_regreso)}
                                    </div>
                                    <span class="hidden sm:inline text-gray-400 text-[10px]">• Verificado</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="flex items-center justify-between sm:justify-end gap-3 w-full sm:w-auto mt-2 sm:mt-0">
                            <div class="text-left sm:text-right mr-2">
                                <p class="text-lg font-extrabold text-lumiDark">
                                    $${Number(precio).toLocaleString('en-US')} 
                                    <span class="text-xs font-normal text-gray-400">${monedaDeal}</span>
                                </p>
                            </div>
                            
                            <button onclick="copiarUrlUnica('${deal.id}')" title="Copiar enlace" class="bg-gray-50 hover:bg-gray-200 text-gray-500 p-2 rounded-lg transition-colors shadow-sm">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                            </button>
                            <span class="text-lumiCyan hover:text-lumiCyanDark font-semibold text-sm flex items-center gap-1 transition-colors">
                                Explorar <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                            </span>
                        </div>
                    `;
                    container.appendChild(li);
                });
            }

            document.getElementById('radar-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                const nombre = document.getElementById('lead-nombre').value;
                const origen = document.getElementById('lead-origen').value;
                const destino = document.getElementById('lead-destino').value;
                const mes = document.getElementById('lead-mes').value;
                const contacto = document.getElementById('lead-contacto').value;
                const btn = e.target.querySelector('button');
                
                btn.innerText = "Activando...";
                btn.disabled = true;

                const { error } = await clienteSupabase
                    .from('radares_personales')
                    .insert([{ nombre: nombre, origen: origen, destino: destino, mes_esperado: mes, contacto: contacto, status: 'pendiente_verificacion' }]);

                if (!error) {
                    document.getElementById('form-exito').classList.remove('hidden');
                    e.target.reset();
                    btn.innerText = "Activar otro Radar";
                } else {
                    alert("Hubo un error al guardar. Revisa la consola.");
                    console.error(error);
                    btn.innerText = "Activar mi Radar 🎯";
                }
                btn.disabled = false;
            });

            document.getElementById('newsletter-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                const email = document.getElementById('nl-email').value.trim().toLowerCase();
                const btn = e.target.querySelector('button');
                const mensaje = document.getElementById('nl-mensaje');
                
                btn.innerText = "Guardando...";
                btn.disabled = true;

                const { error } = await clienteSupabase
                    .from('suscriptores_radar')
                    .insert([{ email: email, pais: paisActual, nombre: 'Viajero' }]);

                mensaje.classList.remove('hidden');

                if (!error) {
                    mensaje.innerText = "¡Listo! Te avisaremos de las mejores gangas.";
                    mensaje.className = "text-center text-sm font-bold mt-3 text-emerald-500 block";
                    e.target.reset();
                    btn.innerText = "Suscrito ✓";
                } else {
                    if (error.code === '23505') {
                        mensaje.innerText = "¡Ya estás en nuestra lista!";
                        mensaje.className = "text-center text-sm font-bold mt-3 text-lumiCyan block";
                    } else {
                        mensaje.innerText = "Error de conexión. Intenta de nuevo.";
                        mensaje.className = "text-center text-sm font-bold mt-3 text-red-500 block";
                    }
                    btn.innerText = "Suscribirme Gratis";
                    btn.disabled = false;
                }
            });

            document.addEventListener('DOMContentLoaded', async () => {
                // FORZADO SEO COSTA RICA
                paisActual = 'CR'; 
                monedaActual = 'USD';
                banderaActual = 'https://flagcdn.com/w20/cr.png';
                
                seleccionarPais(paisActual, monedaActual, banderaActual);
                poblarMeses();
            });
        </script>
    </div>
</Layout>
