            function formatearFechaCorta(fechaCadena) {
                if (!fechaCadena) return '';
                if (!fechaCadena.includes('-')) return fechaCadena;
                const partes = fechaCadena.split('-');
                if (partes.length !== 3) return fechaCadena;
                
                const año = parseInt(partes[0]);
                const mes = parseInt(partes[1]) - 1;
                const dia = parseInt(partes[2]);
                const fechaObj = new Date(año, mes, dia);
                
                const opciones = { day: 'numeric', month: 'short' };
                let formateada = fechaObj.toLocaleDateString('es-ES', opciones);
                return formateada.replace('.', ''); 
            }

            function corregirAño(fechaCadena) {
                if (!fechaCadena || !fechaCadena.includes('-')) return fechaCadena;
                let [y, m, d] = fechaCadena.split('-');
                const hoy = new Date();
                const mesActual = hoy.getMonth() + 1; 
                const añoActual = hoy.getFullYear();

                if (parseInt(m) < mesActual) {
                    y = (añoActual + 1).toString();
                } else {
                    y = añoActual.toString();
                }
                return `${y}-${m}-${d}`;
            }

            function construirLinkVuelo(origen, destino, fechaSalida, fechaRegreso) {
                const ori = (origen || '').trim().replace(/[^A-Za-z]/g, '').substring(0, 3).toUpperCase();
                const des = (destino || '').trim().replace(/[^A-Za-z]/g, '').substring(0, 3).toUpperCase();

                if (ori.length !== 3 || des.length !== 3 || !fechaSalida) {
                    return 'https://vuelos.lumivia.app/';
                }

                const salidaCorregida = corregirAño(fechaSalida);
                let url = `https://vuelos.lumivia.app/flights/?origin_iata=${ori}&destination_iata=${des}&depart_date=${salidaCorregida}&adults=1&with_request=true`;

                if (fechaRegreso && fechaRegreso.trim() !== '' && fechaRegreso.includes('-')) {
                    const regresoCorregido = corregirAño(fechaRegreso);
                    url += `&return_date=${regresoCorregido}`;
                } else {
                    url += `&oneway=1`;
                }

                return url;
            }

            function curarOfertas(data, pais) {
                const nacionales = destinosNacionales[pais] || [];
                const dataLimpia = data.filter(deal => {
                    const esInternacional = !nacionales.includes(deal.destino);
                    if (!esInternacional && deal.fecha_salida && deal.fecha_regreso) {
                        const fIda = new Date(deal.fecha_salida);
                        const fReg = new Date(deal.fecha_regreso);
                        const diasViaje = (fReg - fIda) / (1000 * 60 * 60 * 24);
                        if (diasViaje > 14) return false; 
                    }
                    return true;
                });

                let hookDeals = [];
                let radarDeals = [];
                let combinacionesUsadas = new Set(); 

                const dataOrdenada = dataLimpia.sort((a, b) => {
                    return new Date(b.created_at) - new Date(a.created_at);
                });

                for (let i = 0; i < dataOrdenada.length; i++) {
                    if (hookDeals.length >= 6) break;
                    const deal = dataOrdenada[i];
                    const llaveUnica = deal.destino + '-' + (deal.tipo_vuelo || 'ahorro');

                    if (!combinacionesUsadas.has(llaveUnica)) {
                        hookDeals.push(deal);
                        combinacionesUsadas.add(llaveUnica);
                        deal._curado = true; 
                    }
                }

                let conteoRadar = {};
                for (let i = 0; i < dataOrdenada.length; i++) {
                    const deal = dataOrdenada[i];
                    if (!deal._curado) {
                        const llaveUnica = deal.destino + '-' + (deal.tipo_vuelo || 'ahorro');
                        conteoRadar[llaveUnica] = (conteoRadar[llaveUnica] || 0) + 1;
                        if(conteoRadar[llaveUnica] <= 1) { 
                            radarDeals.push(deal);
                        }
                    }
                }

                return { hookDeals: hookDeals, radarDeals: radarDeals.slice(0, 8) };
            }

